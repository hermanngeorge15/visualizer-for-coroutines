  "components": {
    "schemas": {
      "SessionInfo": {
        "type": "object",
        "required": ["sessionId", "coroutineCount", "eventCount"],
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "coroutineCount": {
            "type": "integer"
          },
          "eventCount": {
            "type": "integer"
          }
        }
      },
      "CreateSessionResponse": {
        "type": "object",
        "required": ["sessionId", "message"],
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "CoroutineState": {
        "type": "string",
        "enum": ["CREATED", "ACTIVE", "SUSPENDED", "WAITING_FOR_CHILDREN", "COMPLETED", "CANCELLED", "FAILED"]
      },
      "CoroutineNodeDto": {
        "type": "object",
        "required": ["id", "jobId", "scopeId", "state"],
        "properties": {
          "id": {
            "type": "string"
          },
          "jobId": {
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "nullable": true
          },
          "scopeId": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "nullable": true
          },
          "state": {
            "type": "string"
          }
        }
      },
      "SessionSnapshotResponse": {
        "type": "object",
        "required": ["sessionId", "coroutineCount", "eventCount", "coroutines"],
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "coroutineCount": {
            "type": "integer"
          },
          "eventCount": {
            "type": "integer"
          },
          "coroutines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CoroutineNodeDto"
            }
          }
        }
      },
      "HierarchyNode": {
        "type": "object",
        "required": ["id", "name", "scopeId", "state", "createdAtNanos", "jobId"],
        "properties": {
          "id": {
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "nullable": true
          },
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "name": {
            "type": "string"
          },
          "scopeId": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "createdAtNanos": {
            "type": "integer",
            "format": "int64"
          },
          "completedAtNanos": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "dispatcherId": {
            "type": "string",
            "nullable": true
          },
          "dispatcherName": {
            "type": "string",
            "nullable": true
          },
          "currentThreadId": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "currentThreadName": {
            "type": "string",
            "nullable": true
          },
          "jobId": {
            "type": "string"
          },
          "exceptionType": {
            "type": "string",
            "nullable": true
          },
          "exceptionMessage": {
            "type": "string",
            "nullable": true
          },
          "activeChildrenIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "activeChildrenCount": {
            "type": "integer",
            "default": 0
          }
        }
      },
      "CoroutineTimeline": {
        "type": "object",
        "required": ["coroutineId", "name", "state"],
        "properties": {
          "coroutineId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "totalDuration": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "Total time from creation to completion in nanoseconds"
          },
          "activeDuration": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "Time spent actively running in nanoseconds"
          },
          "suspendedDuration": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "Time spent suspended in nanoseconds"
          },
          "parentId": {
            "type": "string",
            "nullable": true
          },
          "childrenIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TimelineEventSummary"
            },
            "default": []
          }
        }
      },
      "TimelineEventSummary": {
        "type": "object",
        "required": ["seq", "tsNanos", "kind"],
        "properties": {
          "seq": {
            "type": "integer",
            "format": "int64"
          },
          "tsNanos": {
            "type": "integer",
            "format": "int64"
          },
          "kind": {
            "type": "string"
          },
          "threadName": {
            "type": "string",
            "nullable": true
          },
          "dispatcherName": {
            "type": "string",
            "nullable": true
          },
          "reason": {
            "type": "string",
            "nullable": true,
            "description": "For suspension events"
          }
        }
      },
      "ThreadEvent": {
        "type": "object",
        "required": ["coroutineId", "threadId", "threadName", "timestamp", "eventType"],
        "properties": {
          "coroutineId": {
            "type": "string"
          },
          "threadId": {
            "type": "integer",
            "format": "int64"
          },
          "threadName": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "eventType": {
            "type": "string",
            "enum": ["ASSIGNED", "RELEASED"]
          },
          "dispatcherName": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Scenario": {
        "type": "object",
        "required": ["id", "name", "description", "endpoint"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "endpoint": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": ["realistic", "channel", "basic"]
          },
          "duration": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ScenarioListResponse": {
        "type": "object",
        "required": ["scenarios"],
        "properties": {
          "scenarios": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Scenario"
            }
          }
        }
      },
      "ScenarioCompletionResponse": {
        "type": "object",
        "required": ["success", "sessionId", "message", "coroutineCount", "eventCount"],
        "properties": {
          "success": {
            "type": "boolean"
          },
          "sessionId": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "coroutineCount": {
            "type": "integer"
          },
          "eventCount": {
            "type": "integer"
          }
        }
      },
      "ActionDTO": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["delay", "throw", "log", "custom"]
          },
          "params": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "default": {}
          }
        }
      },
      "CoroutineConfigDTO": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "nullable": true
          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ActionDTO"
            },
            "default": []
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CoroutineConfigDTO"
            },
            "default": []
          }
        }
      },
      "ScenarioConfigRequest": {
        "type": "object",
        "required": ["name", "root"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "sessionId": {
            "type": "string",
            "nullable": true
          },
          "root": {
            "$ref": "#/components/schemas/CoroutineConfigDTO"
          }
        }
      },
      "ScenarioExecutionResponse": {
        "type": "object",
        "required": ["success", "sessionId", "message"],
        "properties": {
          "success": {
            "type": "boolean"
          },
          "sessionId": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "coroutineCount": {
            "type": "integer",
            "default": 0
          },
          "eventCount": {
            "type": "integer",
            "default": 0
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        }
      },
      "ValidationResponse": {
        "type": "object",
        "required": ["sessionId", "results", "timing"],
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationResult"
            }
          },
          "timing": {
            "$ref": "#/components/schemas/TimingReport"
          }
        }
      },
      "ValidationResult": {
        "type": "object",
        "required": ["ruleName", "message"],
        "discriminator": {
          "propertyName": "type"
        },
        "properties": {
          "type": {
            "type": "string",
            "enum": ["Pass", "Fail"]
          },
          "ruleName": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "string",
            "description": "Present only for Fail results"
          }
        }
      },
      "TimingReport": {
        "type": "object",
        "required": ["coroutineDurations", "suspensionDurations", "totalDuration"],
        "properties": {
          "coroutineDurations": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Map of coroutine ID to total duration in nanoseconds"
          },
          "suspensionDurations": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int64"
              }
            },
            "description": "Map of coroutine ID to list of suspension durations in nanoseconds"
          },
          "totalDuration": {
            "type": "integer",
            "format": "int64",
            "description": "Overall duration of the event stream in nanoseconds"
          }
        }
      },
      "ValidationRule": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "VizEvent": {
        "type": "object",
        "description": "Base event shape. Actual events are polymorphic and discriminated by the 'kind' field. See events.ts for full TypeScript types.",
        "required": ["sessionId", "seq", "tsNanos", "kind"],
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "seq": {
            "type": "integer",
            "format": "int64"
          },
          "tsNanos": {
            "type": "integer",
            "format": "int64"
          },
          "kind": {
            "type": "string"
          }
        }
      }
    }
  }
}
